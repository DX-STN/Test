<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <!-- スマホ対応のための必須設定 -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <style>
        body { font-family: sans-serif; padding: 20px; }

        .range-slider {
            position: relative;
            width: 100%; /* スマホ幅に合わせる */
            max-width: 400px;
            height: 60px;
            margin: 40px auto;
            /* 操作中にブラウザのスクロールやリロードを阻止 */
            touch-action: none; 
        }

        input[type="range"] {
            position: absolute;
            width: 100%;
            pointer-events: none;
            appearance: none;
            -webkit-appearance: none;
            background: none;
            margin: 0;
            top: 50%;
            transform: translateY(-50%);
        }

        /* つまみのサイズをスマホでも押しやすく大きく(30px)設定 */
        input[type="range"]::-webkit-slider-thumb {
            height: 30px;
            width: 30px;
            border-radius: 50%;
            background: #007bff;
            cursor: pointer;
            pointer-events: auto;
            appearance: none;
            -webkit-appearance: none;
            border: 2px solid #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        /* 溝のデザイン */
        .slider-track {
            position: absolute;
            width: 100%;
            height: 8px;
            background: #e0e0e0;
            top: 50%;
            transform: translateY(-50%);
            border-radius: 4px;
            z-index: -1;
        }

        .values { text-align: center; font-weight: bold; font-size: 1.2rem; }
    </style>
</head>
<body>

<div class="values">
    <span id="res">20 - 80</span>
</div>

<div class="range-slider">
    <div class="slider-track"></div>
    <input type="range" id="lower" min="0" max="100" value="20">
    <input type="range" id="upper" min="0" max="100" value="80">
</div>

<script>
    const lower = document.getElementById('lower');
    const upper = document.getElementById('upper');
    const res = document.getElementById('res');

    function update(e) {
        let lowVal = parseInt(lower.value);
        let uppVal = parseInt(upper.value);

        if (lowVal > uppVal) {
            if (e.target.id === 'lower') {
                lower.value = uppVal;
            } else {
                upper.value = lowVal;
            }
        }
        res.textContent = `${lower.value} - ${upper.value}`;
    }

    lower.addEventListener('input', update);
    upper.addEventListener('input', update);
</script>

</body>
</html>
